@using ManageEmployee.Models.DTOs

@model EmployeeListViewModel

@{
    ViewData["Title"] = "EmployeeList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Employee List</h1>
@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">
        @ViewBag.ErrorMessage
    </div>
}
@using (Html.BeginForm("EmployeeList", "Employee"))
{
    <table class="table">
        <tr>
            <td>
                <input type="text" name="keyword" id="keyword" class="form-control" placeholder="Enter Name or Title" value="@Model.Keyword" />
            </td>
            <td>
                <input type="submit" name="search" id="search" class="btn btn-primary" value="Search" />
            </td>
        </tr>
    </table>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().SSN)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().DOB)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().FullAddress)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().Salary)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().JoinDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList.First().ExitDate)
            </th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.EmployeeList.Any())
        {
            <tr>
                <td colspan="10" class="text-center">No employees found.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.EmployeeList)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.SSN)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.DOB)
                    </td>
                    <td>
                        @Html.Raw(item.FullAddress)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Phone)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Title)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Salary)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.JoinDate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ExitDate)
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
